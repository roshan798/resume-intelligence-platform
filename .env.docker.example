# Copy to .env.docker or merge these values into the repository .env file.
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-a-long-random-secret
AUTH_URL=http://localhost:3000

POSTGRES_USER=resume
POSTGRES_PASSWORD=resume_local_password
POSTGRES_DB=resume_intelligence
POSTGRES_PORT=5432
APP_PORT=3000
LOG_LEVEL=info
MAX_UPLOAD_SIZE_MB=10

AI_DEFAULT_PROVIDER=gemini
AI_TIMEOUT_MS=30000
AI_RETRY_COUNT=2
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# File storage remains external. Supply an existing Supabase project.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=resumes
