generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"] // 1. Enable preview feature
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")] // 2. Declare the extension
}

enum ResumeVersionStatus {
  MASTER
  TAILORED_DRAFT
  FINAL
  ARCHIVED
}

enum SourceFormat {
  PDF
  DOCX
  LATEX
}

enum ApplicationStatus {
  SAVED
  APPLIED
  OA
  INTERVIEW
  REJECTED
  OFFER
  CLOSED
}

enum AIProvider {
  GROQ
  GEMINI
  OPENAI
  ANTHROPIC
}

enum AISuggestionStatus {
  PROPOSED
  ACCEPTED
  REJECTED
  APPLIED
  MANUALLY_APPLIED
}

enum AISuggestionType {
  MISSING_KEYWORDS
  REWRITE_BULLETS
  SECTION_RECOMMENDATIONS
  TAILORED_DRAFT
  CHANGE_SUMMARY
}

enum StorageProvider {
  SUPABASE
  GOOGLE_DRIVE
}

enum ResumeTagScope {
  RESUME
  VERSION
}

enum IntegrationProvider {
  GOOGLE_DRIVE
}

enum BackgroundJobType {
  PARSE_RESUME
  GENERATE_EMBEDDING
  MATCH_RESUME
  GENERATE_AI
}

enum BackgroundJobStatus {
  QUEUED
  ACTIVE
  COMPLETED
  FAILED
}

enum JobDescriptionStatus {
  ACTIVE
  ARCHIVED
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String?
  name          String?
  image         String?
  role          String    @default("USER")
  emailVerified DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts Account[]
  sessions Session[]

  resumes         Resume[]
  jdAnalyses      JDAnalysis[]
  applications    Application[]
  fileAssets      FileAsset[]
  integrations    Integration[]
  backgroundJobs  BackgroundJob[]
  jobDescriptions JobDescription[]
  aiSettings      AISettings?
  aiUsage         AIUsage[]

  @@map("users")
}

model AISettings {
  id String @id @default(uuid())
  userId String @unique
  preferredProvider AIProvider @default(GEMINI)
  fallbackEnabled Boolean @default(true)
  featureModels Json @default("{}")
  monthlyTokenLimit Int? @default(200000)
  monthlyBudgetMicros Int?
  perRequestMaxTokens Int @default(4000)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("ai_settings")
}

model AIUsage {
  id String @id @default(uuid())
  userId String
  operation String
  provider AIProvider
  modelUsed String
  promptTokens Int @default(0)
  completionTokens Int @default(0)
  totalTokens Int @default(0)
  estimatedCostMicros Int @default(0)
  requestId String
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, createdAt])
  @@index([requestId])
  @@map("ai_usage")
}

model JobDescription {
  id                     String               @id @default(uuid())
  userId                 String
  company                String?
  roleTitle              String
  location               String?
  sourceUrl              String?
  experienceRequirements String?              @db.Text
  status                 JobDescriptionStatus @default(ACTIVE)
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshots JDAnalysis[]

  @@index([userId, status, updatedAt])
  @@index([userId, company])
  @@map("job_descriptions")
}

model Session {
  sessionToken String @unique

  userId String

  expires DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([sessionToken])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String

  refresh_token String? @db.Text
  access_token  String? @db.Text

  expires_at Int?

  token_type String?

  scope String?

  id_token String? @db.Text

  session_state String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Resume {
  id           String   @id @default(uuid())
  userId       String
  title        String
  primaryStack String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  versions ResumeVersion[]
  tags     ResumeTag[]

  @@index([userId, title])
  @@index([userId])
  @@map("resumes")
}

model ResumeVersion {
  id              String  @id @default(uuid())
  resumeId        String
  parentVersionId String?

  versionNumber Int

  status ResumeVersionStatus

  sourceFormat SourceFormat

  rawText String @db.Text

  latexSource String? @db.Text

  latexStyleSource   String? @db.Text
  latexStyleFilename String?

  parsedSections Json

  canonicalKeywords Json

  fingerprintHash String

  fileAssetId String?

  jdSnapshotId String?
  embedding    Unsupported("vector(1536)")?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resume Resume @relation(fields: [resumeId], references: [id], onDelete: Cascade)

  parent ResumeVersion? @relation("ResumeVersionParent", fields: [parentVersionId], references: [id], onDelete: SetNull)

  children ResumeVersion[] @relation("ResumeVersionParent")

  fileAsset FileAsset? @relation(fields: [fileAssetId], references: [id], onDelete: SetNull)

  jdSnapshot JDAnalysis? @relation(fields: [jdSnapshotId], references: [id], onDelete: SetNull)

  matchResults MatchResult[]

  aiSuggestions AISuggestion[]

  applications Application[]

  versionTags ResumeTag[]

  @@index([resumeId])
  @@index([parentVersionId])
  @@index([jdSnapshotId])
  @@index([resumeId, status])
  @@index([resumeId, versionNumber])
  @@map("resume_versions")
}

model ResumeTag {
  id String @id @default(uuid())

  resumeId String

  tag String

  scope ResumeTagScope

  resumeVersionId String?
  resume          Resume         @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  version         ResumeVersion? @relation(fields: [resumeVersionId], references: [id], onDelete: Cascade)

  @@unique([resumeId, tag, resumeVersionId])
  @@index([tag])
  @@index([resumeId])
  @@map("resume_tags")
}

model JDAnalysis {
  id String @id @default(uuid())

  userId String

  jobDescriptionId String?

  snapshotNumber Int @default(1)

  rawText String @db.Text

  company String?

  roleTitle String?

  parsedKeywords Json
  embedding      Unsupported("vector(1536)")?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  jobDescription JobDescription? @relation(fields: [jobDescriptionId], references: [id], onDelete: SetNull)

  matchResults MatchResult[]

  resumeVersions ResumeVersion[]

  applications Application[]

  aiSuggestions AISuggestion[]

  @@unique([jobDescriptionId, snapshotNumber])
  @@index([userId, createdAt])
  @@index([jobDescriptionId])
  @@index([company])
  @@index([roleTitle])
  @@map("jd_analyses")
}

model MatchResult {
  id String @id @default(uuid())

  jdAnalysisId String

  resumeVersionId String

  overallScore Decimal @db.Decimal(5, 2)

  sectionScores Json

  matchedKeywords Json

  missingKeywords Json

  weakKeywords Json

  formattingHealth Json

  createdAt  DateTime   @default(now())
  jdAnalysis JDAnalysis @relation(fields: [jdAnalysisId], references: [id], onDelete: Cascade)

  resumeVersion ResumeVersion @relation(fields: [resumeVersionId], references: [id], onDelete: Cascade)

  @@index([jdAnalysisId, overallScore])
  @@index([resumeVersionId])
  @@map("match_results")
}

model AISuggestion {
  id String @id @default(uuid())

  resumeVersionId String

  jdAnalysisId String?

  featureType AISuggestionType

  inputPayload Json

  outputPayload Json

  status AISuggestionStatus

  provider AIProvider

  modelUsed String

  promptVersion String?
  cacheKey      String? @unique

  promptTokens        Int @default(0)
  completionTokens    Int @default(0)
  totalTokens         Int @default(0)
  estimatedCostMicros Int @default(0)

  createdAt DateTime @default(now())

  resumeVersion ResumeVersion @relation(fields: [resumeVersionId], references: [id], onDelete: Cascade)

  jdAnalysis JDAnalysis? @relation(fields: [jdAnalysisId], references: [id], onDelete: SetNull)

  @@index([provider])
  @@index([resumeVersionId])
  @@index([resumeVersionId, featureType])
  @@index([status, createdAt])
  @@index([resumeVersionId, jdAnalysisId, promptVersion])
  @@map("ai_suggestions")
}

model Application {
  id String @id @default(uuid())

  userId String

  jdAnalysisId String?

  resumeVersionId String

  company String

  roleTitle String

  status ApplicationStatus

  appliedDate DateTime?

  applicationUrl String?

  location String?

  nextAction String?

  nextActionDate DateTime?

  notes String? @db.Text

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  jdAnalysis JDAnalysis? @relation(fields: [jdAnalysisId], references: [id], onDelete: SetNull)

  resumeVersion ResumeVersion @relation(fields: [resumeVersionId], references: [id], onDelete: Cascade)

  history ApplicationStatusHistory[]

  @@index([userId, status])
  @@index([userId, company])
  @@index([userId, createdAt])
  @@index([userId, nextActionDate])
  @@index([resumeVersionId])
  @@map("applications")
}

model ApplicationStatusHistory {
  id String @id @default(uuid())

  applicationId String

  status ApplicationStatus

  changedAt DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("application_status_history")
}

model FileAsset {
  id String @id @default(uuid())

  userId String

  storageProvider StorageProvider

  storageRef String

  mimeType String

  sizeBytes Int

  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  resumeVersions ResumeVersion[]

  @@index([userId])
  @@map("file_assets")
}

model Integration {
  id String @id @default(uuid())

  userId String

  provider IntegrationProvider

  accessToken String

  refreshToken String

  scopes String[]

  connectedAt DateTime @default(now())

  expiresAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@map("integrations")
}

model BackgroundJob {
  id String @id @default(uuid())

  userId String

  type BackgroundJobType

  status BackgroundJobStatus @default(QUEUED)

  queueJobId String?

  progress Int @default(0)

  payload Json

  result Json?

  error String? @db.Text

  createdAt DateTime @default(now())

  startedAt DateTime?

  completedAt DateTime?

  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([type])
  @@map("background_jobs")
}
